# =============================================
# FusionPBX API Bridge - Environment Variables
# =============================================

# Server
PORT=3000
NODE_ENV=development

# JWT Authentication
JWT_SECRET=your-very-strong-secret-key-change-this
JWT_EXPIRES_IN=24h

# =============================================
# Per-Domain API Keys
#
# Format:  DOMAIN_API_KEYS=domain1:key1,domain2:key2,...
#
# Each CRM tenant connects with its own key and is automatically
# locked to that domain only — no domain parameter needed.
#
# Generate strong random keys, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# =============================================
DOMAIN_API_KEYS=company-a.example.com:key_a_replace_me,company-b.example.com:key_b_replace_me

# =============================================
# Admin API Key (optional)
#
# Grants cross-domain access.  Pass ?domain= on each request.
# Leave empty or remove to disable admin access entirely.
# =============================================
ADMIN_API_KEY=admin_super_secret_replace_me

# =============================================
# FusionPBX Connection
# =============================================
FUSIONPBX_HOST=your-fusionpbx-host.example.com
FUSIONPBX_PORT=443
FUSIONPBX_PROTOCOL=https

# FusionPBX Admin Credentials (for REST API)
FUSIONPBX_USERNAME=admin
FUSIONPBX_PASSWORD=your-fusionpbx-admin-password

# =============================================
# FreeSWITCH ESL (Event Socket Library)
# Required for real-time call control
# =============================================
ESL_HOST=your-fusionpbx-host.example.com
ESL_PORT=8021
ESL_PASSWORD=ClueCon

# =============================================
# FusionPBX PostgreSQL Database
# Required for CDR queries and extension data
# =============================================
DB_HOST=your-fusionpbx-host.example.com
DB_PORT=5432
DB_NAME=fusionpbx
DB_USER=fusionpbx
DB_PASSWORD=your-db-password
DB_SSL=true

# =============================================
# CORS - Allowed CRM Origins
# =============================================
CORS_ORIGINS=http://localhost:8080,https://your-crm.example.com

# =============================================
# Rate Limiting
# =============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

# =============================================
# Logging
# =============================================
LOG_LEVEL=info
LOG_FILE=logs/app.log
