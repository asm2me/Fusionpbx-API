# =============================================
# FusionPBX API Bridge - Environment Variables
# =============================================

# Server
PORT=3000
NODE_ENV=development

# JWT Authentication
JWT_SECRET=your-very-strong-secret-key-change-this
JWT_EXPIRES_IN=24h

# API Key Authentication (CRM uses this to connect)
API_KEY=your-crm-api-key-change-this

# =============================================
# FusionPBX Connection
# =============================================
FUSIONPBX_HOST=your-fusionpbx-host.example.com
FUSIONPBX_PORT=443
FUSIONPBX_PROTOCOL=https

# FusionPBX Admin Credentials (for REST API)
FUSIONPBX_USERNAME=admin
FUSIONPBX_PASSWORD=your-fusionpbx-admin-password

# FusionPBX Domain (tenant domain)
FUSIONPBX_DOMAIN=your-domain.example.com

# =============================================
# FreeSWITCH ESL (Event Socket Library)
# Required for real-time call control
# =============================================
ESL_HOST=your-fusionpbx-host.example.com
ESL_PORT=8021
ESL_PASSWORD=ClueCon

# =============================================
# FusionPBX PostgreSQL Database
# Required for CDR queries and extension data
# =============================================
DB_HOST=your-fusionpbx-host.example.com
DB_PORT=5432
DB_NAME=fusionpbx
DB_USER=fusionpbx
DB_PASSWORD=your-db-password
DB_SSL=true

# =============================================
# CORS - Allowed CRM Origins
# =============================================
CORS_ORIGINS=http://localhost:8080,https://your-crm.example.com

# =============================================
# Rate Limiting
# =============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

# =============================================
# Logging
# =============================================
LOG_LEVEL=info
LOG_FILE=logs/app.log
