# =============================================
# FusionPBX API Bridge - Environment Variables
# =============================================

# Server
PORT=3000
NODE_ENV=development

# JWT Authentication
JWT_SECRET=your-very-strong-secret-key-change-this
JWT_EXPIRES_IN=24h

# =============================================
# API Keys
#
# API keys are now stored in the FusionPBX database (v_api_keys table).
# Each key is linked to a FusionPBX user + domain.
# Manage keys via the API:
#
#   POST   /api/apikeys   – create a key for a FusionPBX user
#   GET    /api/apikeys   – list keys for your domain
#   DELETE /api/apikeys/:uuid  – revoke a key
#   PATCH  /api/apikeys/:uuid  – enable/disable a key
#
# Run the migration first:
#   psql -U fusionpbx -d fusionpbx -f migrations/001_create_api_keys.sql
# =============================================

# =============================================
# Bootstrap Admin Key (env only, optional)
#
# Used for initial setup / first key creation before any DB keys exist.
# Has cross-domain access. Leave empty to require all auth through DB keys.
#
# Generate:
#   node -e "console.log('admin_' + require('crypto').randomBytes(24).toString('hex'))"
# =============================================
ADMIN_API_KEY=admin_super_secret_replace_me

# Key cache TTL in ms (default 5 minutes).
# A revoked key stays valid for at most this long after revocation.
# Set to 0 to disable caching (slower but immediate revocation).
KEY_CACHE_TTL_MS=300000

# =============================================
# FusionPBX Connection
# =============================================
FUSIONPBX_HOST=your-fusionpbx-host.example.com
FUSIONPBX_PORT=443
FUSIONPBX_PROTOCOL=https

# FusionPBX Admin Credentials (for REST API)
FUSIONPBX_USERNAME=admin
FUSIONPBX_PASSWORD=your-fusionpbx-admin-password

# =============================================
# FreeSWITCH ESL (Event Socket Library)
# Required for real-time call control
# =============================================
ESL_HOST=your-fusionpbx-host.example.com
ESL_PORT=8021
ESL_PASSWORD=ClueCon

# =============================================
# FusionPBX PostgreSQL Database
# Required for CDR, extensions, and API key storage
# =============================================
DB_HOST=your-fusionpbx-host.example.com
DB_PORT=5432
DB_NAME=fusionpbx
DB_USER=fusionpbx
DB_PASSWORD=your-db-password
DB_SSL=true

# =============================================
# Self-service Signup (email-verified) + SMTP
#
# Powers POST /api/auth/register/start and /register/verify, used by the
# Private Call app to create a SIP account under the signup domain.
# =============================================
SIGNUP_DOMAIN=private.voipat.com
SIGNUP_SIGNALING=wss://private.voipat.com:7443/ws
SIGNUP_EXT_CONTEXT=private.voipat.com
SIGNUP_OUTBOUND_CID=
SIGNUP_STUN=stun:stun.l.google.com:19302
SIGNUP_TURN=
SIGNUP_TURN_USER=
SIGNUP_TURN_PASS=

# SMTP for sending OTP codes. Leave SMTP_HOST empty to log codes instead of
# emailing them (dev only: the code is also returned as dev_code in the response).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Private Call <no-reply@private.voipat.com>

# =============================================
# CORS - Allowed CRM Origins
# =============================================
CORS_ORIGINS=http://localhost:8080,https://your-crm.example.com

# =============================================
# Rate Limiting
# =============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

# =============================================
# Logging
# =============================================
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Google Sign-In (comma-separated OAuth client IDs allowed as id_token audience)
GOOGLE_CLIENT_IDS=
GOOGLE_AUTOPROVISION=true
