# FusionPBX API Bridge — Minimal .env
#
# On a FusionPBX server the DB credentials are auto-detected from
# /etc/fusionpbx/config.conf — you may not need this file at all.
#
# All other settings (ESL, API key, JWT, ports) are managed through
# the FusionPBX Admin UI:  Admin → API Bridge

# ── PostgreSQL bootstrap (only needed without /etc/fusionpbx/config.conf) ─────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=fusionpbx
DB_USER=fusionpbx
DB_PASSWORD=

# ── Optional overrides (normally set via FusionPBX UI) ────────────────────────
# Uncomment for development / testing without a live FusionPBX database.
#ENV=development
#PORT=3000
#ESL_HOST=127.0.0.1
#ESL_PORT=8021
#ESL_PASSWORD=ClueCon
#API_KEY=change-me
#JWT_SECRET=change-me-jwt
#JWT_EXPIRE_HOURS=24
